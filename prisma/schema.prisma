generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ToolUsage {
  id        String   @id @default(cuid())
  toolId    String   // matches ToolId from tools-store
  category  String   // module: pdf, image, video, dev-seo, text-tools, generators, calculators
  action    String   // e.g. "compress", "merge", "convert"
  success   Boolean  @default(true)
  fileSize  Int?     // input file size in bytes (if applicable)
  duration  Int?     // processing time in ms (if applicable)
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([toolId, createdAt])
  @@index([category, createdAt])
  @@index([createdAt])
}

model Feedback {
  id        String   @id @default(cuid())
  toolId    String?  // optional: feedback can be general or tool-specific
  rating    Int      // 1-5
  comment   String?
  email     String?  // optional user email for follow-up
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([toolId])
  @@index([createdAt])
  @@index([rating])
}

model HealthCheck {
  id        String   @id @default(cuid())
  service   String   // e.g. "api", "database", "storage"
  status    String   // "healthy", "degraded", "down"
  latency   Int?     // response time in ms
  message   String?  // optional details
  createdAt DateTime @default(now())

  @@index([service, createdAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  apiKeys       ApiKey[]

  @@index([email])
}

model ApiKey {
  id          String   @id @default(cuid())
  keyHash     String   @unique // SHA-256 hash of the full API key
  keyPrefix   String?  // e.g. "utilyx_aBcD1234" — for display only
  name        String?
  email       String?  // legacy: kept for keys created without user account
  userId      String?  // links to User when created from dashboard
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        String   @default("free") // free, pro, enterprise
  status      String   @default("active") // active, expired, revoked
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?
  usageCount  Int      @default(0)
  ip          String?  // IP that created the key

  @@index([keyHash])
  @@index([status, expiresAt])
  @@index([email])
  @@index([userId])
}

model ApiKeyEvent {
  id        String   @id @default(cuid())
  eventType String   // generated, validated, expired, regenerated
  apiKeyId  String?
  email     String?
  ip        String?
  metadata  String?  // JSON string for extra data (plan, source, etc.)
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([createdAt])
}
